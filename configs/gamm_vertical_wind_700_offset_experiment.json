{
  "selection_id": "uk-gamm-vertical-wind-700-offset-experiment",
  "selection_policy": "Leave-one-UK-radar-out BirdCast-style GAMM experiment. It keeps the selected additive spatial, ERA5, cyclic temporal, and radar-effect structure, using 700-hPa wind as a fixed directional baseline and fitting the residual velocity without duplicate 700-hPa smooths. No season, solar, or time-of-day exclusion is applied.",
  "gamm_options": {
    "spatial_k": 10,
    "meteorology_interactions": [],
    "temporal_smooths": ["day_of_year", "utc_hour"],
    "temporal_interactions": ["seasonal_diurnal"],
    "target_overrides": {
      "mtr_birds_km_h": {
        "intensity_transform": "sqrt",
        "intensity_weights": "mtr_power",
        "intensity_weight_power": 0.2
      },
      "vid_birds_per_km2": {
        "intensity_transform": "cube_root",
        "intensity_weights": "profile_count",
        "include_radar_random_effect": false
      },
      "bird_u_ms": {
        "vector_weights": "uniform",
        "vector_wind_offset": "era5_700",
        "exclude_predictors": ["u_700_ms", "v_700_ms"]
      },
      "bird_v_ms": {
        "vector_weights": "uniform",
        "vector_wind_offset": "era5_700",
        "exclude_predictors": ["u_700_ms", "v_700_ms"]
      }
    }
  }
}
